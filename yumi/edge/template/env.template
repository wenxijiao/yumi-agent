# Yumi Edge Configuration
# ========================================

# Connection code (LAN codes start with ml1_, remote/account codes start with yumi_)
YUMI_CONNECTION_CODE=

# Server that hosts Yumi, for a remote/account connection code
# (e.g. https://api.yumi.nexus). Leave blank for a LAN code or a local server.
YUMI_EDGE_SERVER=

# Edge device name
EDGE_NAME=My_Edge_Node
